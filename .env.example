# ─────────────────────────────────────────────────────────────
# Isan Air Intelligence — Environment Variables
# Copy to .env.local and fill in values from your Supabase project.
# ─────────────────────────────────────────────────────────────

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://qtcptorlmteydcslveqm.supabase.co

# Browser (Realtime subscriptions) — publishable key with host allowlist
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-side only — JWT anon key (no host restriction, works from server/Vercel)
# ต้องตั้งค่านี้ใน Vercel environment variables ด้วย
SUPABASE_ANON_KEY=

# Service role key — server-only, used by cron jobs that write data.
# NEVER expose this to the browser. Optional for read-only deployments.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret required by /api/cron/* routes (sent as Authorization: Bearer <secret>).
CRON_SECRET=

# Shared secret guarding the Python ML endpoint /api/ml/forecast
# (sent as Authorization: Bearer <secret>). Must MATCH the ML_SECRET set in the
# Vercel Dashboard / Vault. The Node cron route forwards it when invoking the
# Python function. Leave blank in local dev to allow unauthenticated calls.
ML_SECRET=

# Optional: override the base URL the cron route uses to reach the Python ML
# function. Defaults to https://$VERCEL_URL on Vercel, http://localhost:3000 locally.
# ML_FORECAST_URL=

